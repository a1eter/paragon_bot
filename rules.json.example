{
  "_comment": "Правила сопоставления ключевых слов → категория в Дребеденьгах. Скопируй в rules.json и адаптируй под свои категории.",
  "patterns": [
    {
      "match": ["кофе", "кава", "kawa"],
      "category_name": "Кафе, рестораны, доставка"
    },
    {
      "match": ["хлеб", "bułka", "chleb"],
      "category_name": "Продукты питания и напитки"
    },
    {
      "match": ["такси", "uber", "bolt"],
      "category_name": "Такси"
    }
  ]
}
