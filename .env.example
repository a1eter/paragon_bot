# Токен от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram user_id через /start в боте. Оставь пустым — пустит всех.
ALLOWED_USER_IDS=123456789,987654321

# Drebedengi API (demo для теста, потом заменишь на личный)
DD_API_ID=demo_api
DD_LOGIN=demo@example.com
DD_PASS=demo

# Валюта по умолчанию (код ISO, например PLN, RUB, USD)
DD_DEFAULT_CURRENCY=PLN

